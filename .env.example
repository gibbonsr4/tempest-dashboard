# Copy this file to .env.local and fill in the real values.
# Never commit .env.local — it's already covered by .gitignore.

# WeatherFlow Tempest personal access token. Server-only; never reaches the browser.
# Generate at https://tempestwx.com/settings/tokens
TEMPEST_TOKEN=

# Numeric station id from the WeatherFlow account that owns the station.
# Required — there is no default. The dashboard surfaces a clear ConfigError
# when this is unset rather than silently using a different station's data.
# Find it in the URL when viewing your station on tempestwx.com:
#   https://tempestwx.com/station/<STATION_ID>
TEMPEST_STATION_ID=

# EPA AirNow API key for AQI lookups. Server-only.
# Free, instant request at https://docs.airnowapi.org/account/request/
AIRNOW_API_KEY=

# api.weather.gov requires a User-Agent identifying the consumer + a contact
# method. Format: "<app-name> (<email>)". Required by NWS Terms of Service for
# public-facing apps; without one the route handler still works but the request
# carries a self-describing nag string.
NWS_USER_AGENT=tempest-dashboard (you@example.com)

# Default color theme on first visit. Optional; defaults to "system".
# Valid values:
#   system — follow the OS's prefers-color-scheme (default; the user
#            can still override via the toggle in the top nav, and
#            the choice persists in localStorage)
#   dark   — dark mode by default, regardless of OS preference
#            (matches the dashboard's design language)
#   light  — light mode by default, regardless of OS preference
# The NEXT_PUBLIC_ prefix is required so the value is available in
# the client bundle (theme is a client-side concern).
NEXT_PUBLIC_DEFAULT_THEME=system
