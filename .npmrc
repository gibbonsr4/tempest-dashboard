# Don't run postinstall / preinstall scripts from any dependency.
# None of the scripts in our transitive deps apply at runtime:
# esbuild's binary installer is redundant (Next.js bundles its own
# esbuild), msw's worker file is for browser-side mocking we don't
# use, workerd is for `wrangler dev` only, sharp / unrs-resolver are
# transitive build-tool deps.
#
# This silences pnpm 10's "Ignored build scripts" warning at install
# time. With this set, the list of skipped scripts is empty and no
# warning prints — cleaner than maintaining an `ignoredBuiltDependencies`
# list that drifts as transitive deps change.
ignore-scripts=true
